<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部导航 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingBottom="20dp">
            <Button android:id="@+id/btn_back"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="← 返回" android:textSize="13sp"
                android:backgroundTint="#2A2A4A" android:textColor="#AAAAAA"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="智能灵敏度分析"
                android:textColor="#FF4655" android:textSize="20sp"
                android:textStyle="bold" android:gravity="center"/>
            <View android:layout_width="80dp" android:layout_height="1dp"/>
        </LinearLayout>

        <!-- 采集状态卡片 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_background"
            android:padding="16dp" android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingBottom="10dp">
                <TextView android:id="@+id/tv_status"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="📡 实时采集中…"
                    android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tv_sample_count"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 次" android:textColor="#888888" android:textSize="12sp"/>
            </LinearLayout>

            <ProgressBar android:id="@+id/progress_confidence"
                android:layout_width="match_parent" android:layout_height="6dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:progressTint="#FF4655" android:progress="0"/>
            <TextView android:id="@+id/tv_confidence_label"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="置信度 0%" android:textColor="#666666"
                android:textSize="11sp" android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- 腰射推荐卡片 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_background"
            android:padding="16dp" android:layout_marginBottom="12dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔫 腰射视角" android:textColor="#888888"
                android:textSize="12sp" android:paddingBottom="12dp"/>

            <!-- 当前值 → 推荐值 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="当前" android:textColor="#666666" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_hipfire_current"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1.0" android:textColor="#CCCCCC"
                        android:textSize="40sp" android:textStyle="bold"/>
                </LinearLayout>

                <TextView android:id="@+id/tv_hipfire_arrow"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="=" android:textColor="#00BF63"
                    android:textSize="28sp" android:paddingHorizontal="12dp"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="推荐" android:textColor="#666666" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_hipfire_recommended"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1.0" android:textColor="#00BF63"
                        android:textSize="40sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 诊断文字 -->
            <TextView android:id="@+id/tv_hipfire_diagnosis"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="采集中…" android:textColor="#888888"
                android:textSize="13sp" android:paddingTop="12dp"
                android:background="#0A0A1E" android:padding="10dp"/>
        </LinearLayout>

        <!-- 开镜推荐卡片 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_background"
            android:padding="16dp" android:layout_marginBottom="20dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔭 开镜/瞄准镜" android:textColor="#888888"
                android:textSize="12sp" android:paddingBottom="12dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="当前" android:textColor="#666666" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_aimsight_current"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0.6" android:textColor="#CCCCCC"
                        android:textSize="40sp" android:textStyle="bold"/>
                </LinearLayout>

                <TextView android:id="@+id/tv_aimsight_arrow"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="=" android:textColor="#00BF63"
                    android:textSize="28sp" android:paddingHorizontal="12dp"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="推荐" android:textColor="#666666" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_aimsight_recommended"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0.6" android:textColor="#00BF63"
                        android:textSize="40sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <TextView android:id="@+id/tv_aimsight_diagnosis"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="采集中…" android:textColor="#888888"
                android:textSize="13sp" android:paddingTop="12dp"
                android:background="#0A0A1E" android:padding="10dp"/>
        </LinearLayout>

        <!-- 操作按钮 -->
        <Button android:id="@+id/btn_apply"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="✨ 应用推荐值"
            android:textSize="16sp" android:textStyle="bold"
            android:backgroundTint="#FF4655" android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp" android:enabled="false" android:alpha="0.4"/>

        <Button android:id="@+id/btn_clear"
            android:layout_width="match_parent" android:layout_height="42dp"
            android:text="🗑 清除数据重新采集"
            android:textSize="13sp" android:backgroundTint="#2A2A4A"
            android:textColor="#888888" android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>
