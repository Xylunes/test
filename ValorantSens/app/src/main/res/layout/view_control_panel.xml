<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/panel_background"
    android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="⚡ 灵敏度" android:textColor="#FF4655"
        android:textSize="14sp" android:textStyle="bold" android:paddingBottom="12dp"/>

    <!-- 滑屏一键调节 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="2dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="滑屏整体"
            android:textColor="#CCCCCC" android:textSize="12sp"/>
        <TextView android:id="@+id/tv_panel_slide_overall"
            android:layout_width="40dp" android:layout_height="wrap_content"
            android:text="114%" android:textColor="#FF4655"
            android:textSize="12sp" android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>
    <SeekBar android:id="@+id/sb_panel_slide_overall"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:max="199" android:progress="113"
        android:progressTint="#FF4655" android:thumbTint="#FF4655"
        android:layout_marginBottom="10dp"/>

    <!-- 滑屏垂直Y轴 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="2dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="滑屏垂直(Y轴)"
            android:textColor="#CCCCCC" android:textSize="12sp"/>
        <TextView android:id="@+id/tv_panel_slide_vertical"
            android:layout_width="40dp" android:layout_height="wrap_content"
            android:text="28%" android:textColor="#FF4655"
            android:textSize="12sp" android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>
    <SeekBar android:id="@+id/sb_panel_slide_vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:max="199" android:progress="27"
        android:progressTint="#FF4655" android:thumbTint="#FF4655"
        android:layout_marginBottom="12dp"/>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#333355" android:layout_marginBottom="12dp"/>

    <!-- 陀螺仪整体 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="2dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="陀螺仪整体"
            android:textColor="#CCCCCC" android:textSize="12sp"/>
        <TextView android:id="@+id/tv_panel_gyro_overall"
            android:layout_width="40dp" android:layout_height="wrap_content"
            android:text="172%" android:textColor="#FF4655"
            android:textSize="12sp" android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>
    <SeekBar android:id="@+id/sb_panel_gyro_overall"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:max="199" android:progress="171"
        android:progressTint="#FF4655" android:thumbTint="#FF4655"
        android:layout_marginBottom="10dp"/>

    <!-- 陀螺仪垂直Y轴 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="2dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="陀螺仪垂直(Y轴)"
            android:textColor="#CCCCCC" android:textSize="12sp"/>
        <TextView android:id="@+id/tv_panel_gyro_vertical"
            android:layout_width="40dp" android:layout_height="wrap_content"
            android:text="49%" android:textColor="#FF4655"
            android:textSize="12sp" android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>
    <SeekBar android:id="@+id/sb_panel_gyro_vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:max="199" android:progress="48"
        android:progressTint="#FF4655" android:thumbTint="#FF4655"
        android:layout_marginBottom="12dp"/>

    <!-- 关闭按钮 -->
    <Button android:id="@+id/btn_panel_close"
        android:layout_width="match_parent" android:layout_height="36dp"
        android:text="关闭" android:backgroundTint="#2A2A4A"
        android:textColor="#888888" android:textSize="13sp"/>
</LinearLayout>
