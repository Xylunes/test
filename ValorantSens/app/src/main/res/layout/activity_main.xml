<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚡ 无畏契约灵敏度调节"
            android:textColor="#FF4655" android:textSize="20sp"
            android:textStyle="bold" android:paddingBottom="20dp"/>

        <!-- 权限状态卡片 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_background"
            android:padding="14dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="权限状态" android:textColor="#FFFFFF"
                android:textSize="14sp" android:textStyle="bold" android:paddingBottom="8dp"/>
            <TextView android:id="@+id/tv_overlay_status"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="● 悬浮窗权限" android:textColor="#888888" android:textSize="13sp"/>
            <TextView android:id="@+id/tv_accessibility_status"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="● 无障碍服务" android:textColor="#888888"
                android:textSize="13sp" android:paddingTop="4dp"/>
            <Button android:id="@+id/btn_request_permissions"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="去授权" android:backgroundTint="#FF4655"
                android:textColor="#FFFFFF" android:textSize="12sp"
                android:layout_marginTop="8dp" android:visibility="gone"/>
        </LinearLayout>

        <!-- ══ 滑屏设置 ══ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_background"
            android:padding="16dp" android:layout_marginBottom="12dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📱 滑屏设置" android:textColor="#FFFFFF"
                android:textSize="15sp" android:textStyle="bold" android:paddingBottom="16dp"/>

            <!-- 滑屏 一键调节 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="灵敏度一键调节"
                    android:textColor="#CCCCCC" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_slide_overall_val"
                    android:layout_width="52dp" android:layout_height="wrap_content"
                    android:text="114%" android:textColor="#FF4655"
                    android:textSize="14sp" android:textStyle="bold" android:gravity="end"/>
            </LinearLayout>
            <SeekBar android:id="@+id/sb_slide_overall"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="199" android:progress="113"
                android:progressTint="#FF4655" android:thumbTint="#FF4655"
                android:layout_marginBottom="16dp"/>

            <!-- 滑屏 垂直Y轴 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="垂直灵敏度（Y轴）"
                    android:textColor="#CCCCCC" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_slide_vertical_val"
                    android:layout_width="52dp" android:layout_height="wrap_content"
                    android:text="28%" android:textColor="#FF4655"
                    android:textSize="14sp" android:textStyle="bold" android:gravity="end"/>
            </LinearLayout>
            <SeekBar android:id="@+id/sb_slide_vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="199" android:progress="27"
                android:progressTint="#FF4655" android:thumbTint="#FF4655"/>
        </LinearLayout>

        <!-- ══ 陀螺仪设置 ══ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_background"
            android:padding="16dp" android:layout_marginBottom="12dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌀 陀螺仪设置" android:textColor="#FFFFFF"
                android:textSize="15sp" android:textStyle="bold" android:paddingBottom="14dp"/>

            <!-- 陀螺仪开关 三选一 -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="陀螺仪模式" android:textColor="#888888"
                android:textSize="12sp" android:paddingBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <Button android:id="@+id/btn_gyro_off"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:text="关闭"
                    android:textSize="13sp" android:backgroundTint="#FF4655"
                    android:textColor="#FFFFFF" android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btn_gyro_aim"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:text="开镜开启"
                    android:textSize="13sp" android:backgroundTint="#2A2A4A"
                    android:textColor="#AAAAAA" android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btn_gyro_always"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:text="总是开启"
                    android:textSize="13sp" android:backgroundTint="#2A2A4A"
                    android:textColor="#AAAAAA"/>
            </LinearLayout>

            <!-- 陀螺仪灵敏度（仅开启时可调） -->
            <LinearLayout android:id="@+id/layout_gyro_sliders"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 陀螺仪 一键调节 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="灵敏度一键调节"
                        android:textColor="#CCCCCC" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_gyro_overall_val"
                        android:layout_width="52dp" android:layout_height="wrap_content"
                        android:text="172%" android:textColor="#FF4655"
                        android:textSize="14sp" android:textStyle="bold" android:gravity="end"/>
                </LinearLayout>
                <SeekBar android:id="@+id/sb_gyro_overall"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="199" android:progress="171"
                    android:progressTint="#FF4655" android:thumbTint="#FF4655"
                    android:layout_marginBottom="16dp"/>

                <!-- 陀螺仪 垂直Y轴 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="垂直灵敏度（Y轴）"
                        android:textColor="#CCCCCC" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_gyro_vertical_val"
                        android:layout_width="52dp" android:layout_height="wrap_content"
                        android:text="49%" android:textColor="#FF4655"
                        android:textSize="14sp" android:textStyle="bold" android:gravity="end"/>
                </LinearLayout>
                <SeekBar android:id="@+id/sb_gyro_vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="199" android:progress="48"
                    android:progressTint="#FF4655" android:thumbTint="#FF4655"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 预设方案 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_background"
            android:padding="14dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="快速预设" android:textColor="#FFFFFF"
                android:textSize="14sp" android:textStyle="bold" android:paddingBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button android:id="@+id/btn_preset_low"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:text="低"
                    android:backgroundTint="#2A2A4A" android:textColor="#AAAAAA"
                    android:textSize="14sp" android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btn_preset_mid"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:text="中"
                    android:backgroundTint="#2A2A4A" android:textColor="#AAAAAA"
                    android:textSize="14sp" android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btn_preset_high"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:text="高"
                    android:backgroundTint="#2A2A4A" android:textColor="#AAAAAA"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 启动按钮 -->
        <Button android:id="@+id/btn_toggle_service"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="▶ 启动悬浮球"
            android:textSize="18sp" android:textStyle="bold"
            android:backgroundTint="#00BF63" android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <!-- 分析工具入口 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_background"
            android:padding="16dp" android:layout_marginBottom="32dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="分析工具" android:textColor="#FFFFFF"
                android:textSize="15sp" android:textStyle="bold" android:paddingBottom="12dp"/>

            <TextView android:id="@+id/tv_session_count_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="开启悬浮球打游戏后自动采集数据"
                android:textColor="#666666" android:textSize="12sp" android:paddingBottom="12dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingBottom="10dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📊 数据分析" android:textColor="#CCCCCC" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="基于偏差算法给出推荐值" android:textColor="#666666" android:textSize="11sp"/>
                </LinearLayout>
                <Button android:id="@+id/btn_open_analysis"
                    android:layout_width="wrap_content" android:layout_height="38dp"
                    android:text="查看 →" android:backgroundTint="#2A2A5A"
                    android:textColor="#AAAAAA" android:textSize="13sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#2A2A4A" android:layout_marginBottom="10dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🤖 AI 深度分析" android:textColor="#CCCCCC" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="DeepSeek 理解你的打法给出方案" android:textColor="#666666" android:textSize="11sp"/>
                </LinearLayout>
                <Button android:id="@+id/btn_open_ai_analysis"
                    android:layout_width="wrap_content" android:layout_height="38dp"
                    android:text="分析 →" android:backgroundTint="#FF4655"
                    android:textColor="#FFFFFF" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
