<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="16dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部导航 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="24dp">
            <Button android:id="@+id/btn_back_ai"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="← 返回" android:textSize="13sp"
                android:backgroundTint="#2A2A4A" android:textColor="#AAAAAA"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🤖 AI 分析"
                android:textColor="#FF4655" android:textSize="20sp"
                android:textStyle="bold" android:gravity="center"/>
            <View android:layout_width="80dp" android:layout_height="1dp"/>
        </LinearLayout>

        <!-- API Key -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_background"
            android:padding="16dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔑 DeepSeek API Key" android:textColor="#FFFFFF"
                android:textSize="14sp" android:textStyle="bold" android:paddingBottom="10dp"/>
            <EditText android:id="@+id/et_api_key"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:hint="粘贴 sk-... 开头的 Key"
                android:textColor="#FFFFFF" android:textColorHint="#444444"
                android:background="#0D0D2E" android:padding="12dp"
                android:textSize="13sp" android:inputType="textPassword"
                android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/tv_key_status"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="未设置"
                    android:textColor="#666666" android:textSize="13sp"/>
                <Button android:id="@+id/btn_save_key"
                    android:layout_width="wrap_content" android:layout_height="38dp"
                    android:text="保存" android:backgroundTint="#2A2A5A"
                    android:textColor="#AAAAAA" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 分析按钮 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_background"
            android:padding="16dp" android:layout_marginBottom="12dp">
            <TextView android:id="@+id/tv_samples"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="已采集 0 次数据" android:textColor="#888888"
                android:textSize="13sp" android:paddingBottom="12dp"/>
            <Button android:id="@+id/btn_analyze"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="🚀 开始 AI 分析" android:textSize="17sp" android:textStyle="bold"
                android:backgroundTint="#FF4655" android:textColor="#FFFFFF"/>
            <ProgressBar android:id="@+id/progress_analyzing"
                android:layout_width="match_parent" android:layout_height="4dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:progressTint="#FF4655" android:indeterminate="true"
                android:layout_marginTop="12dp" android:visibility="gone"/>
        </LinearLayout>

        <!-- 错误 -->
        <TextView android:id="@+id/tv_error"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#FF6B6B" android:textSize="13sp"
            android:background="#1A0D0D" android:padding="12dp"
            android:layout_marginBottom="12dp" android:visibility="gone"/>

        <!-- 推荐结果 -->
        <LinearLayout android:id="@+id/layout_result"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_background"
                android:padding="24dp" android:layout_marginBottom="12dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="推荐配置" android:textColor="#888888"
                    android:textSize="12sp" android:paddingBottom="20dp"/>

                <!-- 滑屏整体 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="滑屏整体" android:textColor="#666666" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_slide_overall_result"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textColor="#FFB347"
                    android:textSize="36sp" android:textStyle="bold" android:paddingBottom="16dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#222240" android:layout_marginBottom="16dp"/>

                <!-- 滑屏Y轴 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="滑屏垂直（Y轴）" android:textColor="#666666" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_slide_vertical_result"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textColor="#FFB347"
                    android:textSize="36sp" android:textStyle="bold" android:paddingBottom="16dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#222240" android:layout_marginBottom="16dp"/>

                <!-- 陀螺仪模式 -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="陀螺仪模式" android:textColor="#666666" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_gyro_mode_result"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textColor="#FFB347"
                    android:textSize="22sp" android:textStyle="bold" android:paddingBottom="16dp"/>

                <!-- 陀螺仪灵敏度（条件显示） -->
                <LinearLayout android:id="@+id/layout_gyro_result"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:visibility="gone">

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#222240" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="陀螺仪整体" android:textColor="#666666" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_gyro_overall_result"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textColor="#FFB347"
                        android:textSize="36sp" android:textStyle="bold" android:paddingBottom="16dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#222240" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="陀螺仪垂直（Y轴）" android:textColor="#666666" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_gyro_vertical_result"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textColor="#FFB347"
                        android:textSize="36sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 应用按钮 -->
            <Button android:id="@+id/btn_apply_ai"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="✨ 应用 AI 推荐"
                android:textSize="16sp" android:textStyle="bold"
                android:backgroundTint="#FF4655" android:textColor="#FFFFFF"
                android:layout_marginBottom="32dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
